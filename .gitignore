# .gitignore for OrderManagementSystem
# Ignore build output
bin/
obj/

# Ignore user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore debug files
*.pdb
*.log
*.vspscc
*.vssscc

# Ignore VS Code settings
.vscode/

# Ignore launch settings
Properties/launchSettings.json

# Ignore other common files
*.db
*.DS_Store
*.swp
*.tmp
*.bak

# Ignore environment files
.env

# Ignore HTTP files
*.http

# Ignore test results
TestResults/

# Ignore NuGet packages
*.nupkg

# Ignore coverage reports
coverage/
*.coverage
*.coveragexml

# Ignore node_modules if present
node_modules/
